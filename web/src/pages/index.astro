---
// 브라우저에서 직접 호출하므로 호스트에 퍼블리시된 API 포트를 기본값으로 사용한다.
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8081';
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>로그인</title>
  </head>
  <body class="m-0 min-h-screen grid place-items-center bg-slate-900 text-slate-200">
    <main class="w-[min(360px,90vw)] p-8 rounded-2xl bg-slate-800 shadow-2xl">
      <h1 class="mb-6 text-2xl text-center">로그인</h1>
      <form id="auth-form">
        <label class="block mb-4 text-sm">
          이메일
          <input
            type="email"
            name="email"
            required
            autocomplete="username"
            class="w-full mt-1.5 px-3 py-2.5 border border-slate-700 rounded-lg bg-slate-900 text-inherit"
          />
        </label>
        <label class="block mb-4 text-sm">
          비밀번호
          <input
            type="password"
            name="password"
            required
            autocomplete="current-password"
            class="w-full mt-1.5 px-3 py-2.5 border border-slate-700 rounded-lg bg-slate-900 text-inherit"
          />
        </label>
        <div class="flex gap-3 mt-2">
          <button
            type="button"
            id="signup-btn"
            class="flex-1 py-2.5 rounded-lg text-white font-semibold cursor-pointer bg-slate-700 disabled:opacity-60 disabled:cursor-default"
          >가입</button>
          <button
            type="submit"
            id="login-btn"
            class="flex-1 py-2.5 rounded-lg text-white font-semibold cursor-pointer bg-indigo-500 disabled:opacity-60 disabled:cursor-default"
          >로그인</button>
        </div>
      </form>
      <div id="result" class="mt-5 min-h-6 text-center"></div>
    </main>

    <script define:vars={{ apiUrl }}>
      const form = document.getElementById('auth-form');
      const result = document.getElementById('result');
      const signupBtn = document.getElementById('signup-btn');
      const loginBtn = document.getElementById('login-btn');

      // #result 의 상태별 Tailwind 클래스 (전체 문자열이라 JIT 스캔에 잡힌다)
      const RESULT_BASE = 'mt-5 min-h-6 text-center';
      const RESULT_STATE = {
        ok: 'text-3xl font-bold text-green-500',
        err: 'text-3xl font-bold text-red-500',
        okSmall: 'text-base font-medium text-green-500',
        errSmall: 'text-base font-medium text-red-500',
      };

      function showResult(text, state) {
        result.textContent = text;
        result.className = `${RESULT_BASE} ${RESULT_STATE[state]}`;
      }

      async function submit(action) {
        if (!form.reportValidity()) return;

        result.textContent = '';
        result.className = RESULT_BASE;
        signupBtn.disabled = true;
        loginBtn.disabled = true;

        const data = Object.fromEntries(new FormData(form).entries());

        try {
          const res = await fetch(`${apiUrl}/${action}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          const payload = await res.json().catch(() => ({}));

          if (action === 'login') {
            // 로그인: DB 대조 결과에 따라 OK / Fail
            showResult(res.ok ? 'OK' : 'Fail', res.ok ? 'ok' : 'err');
          } else {
            // 가입: DB 저장 성공/중복 안내
            if (res.ok) {
              showResult('가입 완료', 'okSmall');
            } else {
              showResult(payload.message || '가입 실패', 'errSmall');
            }
          }
        } catch (err) {
          showResult(`요청 실패: ${err.message}`, 'err');
        } finally {
          signupBtn.disabled = false;
          loginBtn.disabled = false;
        }
      }

      // 로그인 버튼 = form submit
      form.addEventListener('submit', (event) => {
        event.preventDefault();
        submit('login');
      });
      // 가입 버튼
      signupBtn.addEventListener('click', () => submit('signup'));
    </script>
  </body>
</html>
