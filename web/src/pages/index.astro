---
// 브라우저에서 직접 호출하므로 호스트에 퍼블리시된 API 포트를 기본값으로 사용한다.
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8081';
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>로그인</title>
    <style>
      :root {
        color-scheme: light dark;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      }
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: #0f172a;
        color: #e2e8f0;
      }
      .card {
        width: min(360px, 90vw);
        padding: 2rem;
        border-radius: 16px;
        background: #1e293b;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.35);
      }
      h1 {
        margin: 0 0 1.5rem;
        font-size: 1.4rem;
        text-align: center;
      }
      label {
        display: block;
        margin-bottom: 1rem;
        font-size: 0.85rem;
      }
      input {
        width: 100%;
        margin-top: 0.35rem;
        padding: 0.65rem 0.75rem;
        border: 1px solid #334155;
        border-radius: 8px;
        background: #0f172a;
        color: inherit;
        box-sizing: border-box;
      }
      .buttons {
        display: flex;
        gap: 0.75rem;
        margin-top: 0.5rem;
      }
      button {
        flex: 1;
        padding: 0.7rem;
        border: none;
        border-radius: 8px;
        color: white;
        font-weight: 600;
        cursor: pointer;
      }
      button.login {
        background: #6366f1;
      }
      button.signup {
        background: #334155;
      }
      button:disabled {
        opacity: 0.6;
        cursor: default;
      }
      #result {
        margin-top: 1.25rem;
        min-height: 1.5rem;
        text-align: center;
        font-size: 1.8rem;
        font-weight: 700;
      }
      #result.ok {
        color: #22c55e;
      }
      #result.err {
        color: #ef4444;
      }
      #result.small {
        font-size: 0.95rem;
        font-weight: 500;
      }
    </style>
  </head>
  <body>
    <main class="card">
      <h1>로그인</h1>
      <form id="auth-form">
        <label>
          이메일
          <input type="email" name="email" required autocomplete="username" />
        </label>
        <label>
          비밀번호
          <input type="password" name="password" required autocomplete="current-password" />
        </label>
        <div class="buttons">
          <button type="button" class="signup" id="signup-btn">가입</button>
          <button type="submit" class="login" id="login-btn">로그인</button>
        </div>
      </form>
      <div id="result"></div>
    </main>

    <script define:vars={{ apiUrl }}>
      const form = document.getElementById('auth-form');
      const result = document.getElementById('result');
      const signupBtn = document.getElementById('signup-btn');
      const loginBtn = document.getElementById('login-btn');

      async function submit(action) {
        if (!form.reportValidity()) return;

        result.textContent = '';
        result.className = '';
        signupBtn.disabled = true;
        loginBtn.disabled = true;

        const data = Object.fromEntries(new FormData(form).entries());

        try {
          const res = await fetch(`${apiUrl}/${action}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          const payload = await res.json().catch(() => ({}));

          if (action === 'login') {
            // 로그인: DB 대조 결과에 따라 OK / Fail
            result.textContent = res.ok ? 'OK' : 'Fail';
            result.className = res.ok ? 'ok' : 'err';
          } else {
            // 가입: DB 저장 성공/중복 안내
            if (res.ok) {
              result.textContent = '가입 완료';
              result.className = 'ok small';
            } else {
              result.textContent = payload.message || '가입 실패';
              result.className = 'err small';
            }
          }
        } catch (err) {
          result.textContent = `요청 실패: ${err.message}`;
          result.className = 'err';
        } finally {
          signupBtn.disabled = false;
          loginBtn.disabled = false;
        }
      }

      // 로그인 버튼 = form submit
      form.addEventListener('submit', (event) => {
        event.preventDefault();
        submit('login');
      });
      // 가입 버튼
      signupBtn.addEventListener('click', () => submit('signup'));
    </script>
  </body>
</html>
